# Dev image for the gateway. Built from the repo ROOT context (see
# docker-compose.yml) so the workspace + @finance-ai/shared are available.
FROM node:20-alpine

WORKDIR /repo

# Install workspace deps using the manifests + root lockfile.
COPY package.json package-lock.json ./
COPY packages/shared/package.json packages/shared/package.json
COPY services/gateway/package.json services/gateway/package.json
RUN npm ci

# Build the shared package so its dist (JS + types) is available at runtime.
COPY packages/shared packages/shared
RUN npm run build -w @finance-ai/shared

# Gateway source.
COPY services/gateway services/gateway

WORKDIR /repo/services/gateway
EXPOSE 8080
CMD ["npm", "run", "dev"]
