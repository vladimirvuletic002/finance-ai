NODE_ENV=development
PORT=your_port
DATABASE_URL=your_db_url
JWT_SECRET_KEY=your_jwt_secret
JWT_EXPIRES_IN=1h
GEMINI_API_KEY=gemini_api_key
# Optional. When set, rate limiting, the AI usage quota, and insight-refresh
# dispatch use Redis (shared across instances) instead of in-memory state.
# Leave unset to run single-node with in-memory fallbacks.
REDIS_URL=redis://localhost:6379
