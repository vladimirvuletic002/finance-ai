generator client {
  provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url = env("DATABASE_URL")
}

model User {
	id           Int           @id @default(autoincrement())
	email        String        @unique
	passwordHash String
	name         String?
	createdAt    DateTime      @default(now())
	updatedAt    DateTime      @updatedAt

	categories   Category[]
	transactions Transaction[]
	insights     AIInsight[]
	savingsGoals SavingsGoal[]
}

model Category {
	id        Int           @id @default(autoincrement())
	userId    Int?
	name      String
	isDefault Boolean       @default(false) // true for global default categories
	icon      String?       // optional
	color     String?       // optional
	createdAt DateTime      @default(now())
	updatedAt DateTime      @updatedAt
	deletedAt DateTime?

	user       User?        @relation(fields: [userId], references: [id])
	transactions Transaction[]

	@@index([userId])
	@@unique([userId, name])
}

model Transaction {
	id          Int       @id @default(autoincrement())
	userId      Int
	categoryId  Int
	type        TransactionType
	amount      Decimal    @db.Decimal(10,2)
	currency    String     @default("EUR")
	note        String?
	merchant    String?
	date        DateTime
	createdAt   DateTime   @default(now())

	user      User     @relation(fields: [userId], references: [id])
	category  Category @relation(fields: [categoryId], references: [id])

	@@index([userId, date])
	@@index([userId, type, date])
	@@index([userId, categoryId, date])
	@@index([userId, merchant, date])
}

enum TransactionType {
	INCOME
	EXPENSE
}

model AIInsight {
	id                             Int      @id @default(autoincrement())
	userId                         Int

	month                          Int
	year                           Int

	spendingChangeCurrentMonth     Decimal  @db.Decimal(10,2)
	spendingChangePreviousMonth    Decimal  @db.Decimal(10,2)
	spendingChangePercent          Decimal  @db.Decimal(10,2)
	spendingChangeDirection        String

	predictedRecurringCosts        Decimal  @db.Decimal(10,2)

	topCategoryId                  Int?
	topCategoryName                String?
	topCategoryTotalSpent          Decimal  @db.Decimal(10,2)
	currency                       String

	savingsGoalTitle               String?
	savingsGoalAmount              Decimal  @db.Decimal(10,2)
	currentSavingsEstimate         Decimal  @db.Decimal(10,2)
	savingsProgressPercent         Decimal  @db.Decimal(10,2)
	savingsRemainingAmount         Decimal  @db.Decimal(10,2)

	aiRecommendation               String

	recurringTransactionsJson      Json?
	metaJson                       Json?

	createdAt                      DateTime @default(now())
	updatedAt                      DateTime @updatedAt

	user User @relation(fields: [userId], references: [id])

	@@unique([userId, year, month])
	}

enum InsightType {
	SUMMARY
	FORECAST
	ADVICE
}

model SavingsGoal {
	id            Int      @id @default(autoincrement())
	userId        Int
	title         String   @default("Main savings goal")
	targetAmount  Decimal  @db.Decimal(10,2)
	currency      String   @default("EUR")
	isActive      Boolean  @default(true)
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	user User @relation(fields: [userId], references: [id])

	@@index([userId, isActive])
}
